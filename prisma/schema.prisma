generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  passwordHash     String
  name             String
  bio              String?
  defaultTone      String          @default("professional")
  defaultLanguage  String          @default("en")
  createdAt        DateTime        @default(now())
  refreshTokenHash String?

  socialAccounts   SocialAccount[]
  aiKeys           AiKeys?
  posts            Post[]
}

model SocialAccount {
  id               String   @id @default(cuid())
  userId           String
  platform         String   // twitter | linkedin | instagram | threads
  accessTokenEnc   String   // AES-256 encrypted
  refreshTokenEnc  String?  // AES-256 encrypted
  handle           String?
  connectedAt      DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id])

  @@index([userId, platform])
}

model AiKeys {
  id               String   @id @default(cuid())
  userId           String   @unique
  openaiKeyEnc     String?  // AES-256 encrypted
  anthropicKeyEnc  String?  // AES-256 encrypted
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id])
}

model Post {
  id             String         @id @default(cuid())
  userId         String
  idea           String
  postType       String         // announcement | thread | story | promotional | educational | opinion
  tone           String
  language       String         @default("en")
  modelUsed      String         // openai | anthropic
  status         String         @default("queued") // queued | processing | published | partial | failed | cancelled
  publishAt      DateTime?
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())

  user           User           @relation(fields: [userId], references: [id])
  platformPosts  PlatformPost[]

  @@index([userId, status])
  @@index([publishAt])
}

model PlatformPost {
  id            String    @id @default(cuid())
  postId        String
  platform      String    // twitter | linkedin | instagram | threads
  content       String
  status        String    @default("queued") // queued | processing | published | failed | cancelled
  publishedAt   DateTime?
  errorMessage  String?
  attempts      Int       @default(0)

  post          Post      @relation(fields: [postId], references: [id])

  @@index([postId, platform])
  @@index([status])
}
